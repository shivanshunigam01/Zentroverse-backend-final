# Server
PORT=8787
NODE_ENV=development
CORS_ORIGIN=http://localhost:8080,http://localhost:5173,https://zentroverse.com

# MongoDB (Atlas URI for production; local mongod or USE_MEMORY_DB=true for dev)
MONGODB_URI=mongodb://127.0.0.1:27017/zentroverse
# USE_MEMORY_DB=true

# Admin API
ADMIN_PANEL_TOKEN=ZV-ADMIN-2026-DEMO

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=zentroverse

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Lead notifications
LEAD_WEBHOOK_URL=
WHATSAPP_NOTIFY_URL=
ADMIN_NOTIFY_EMAIL=digital@zentroverse.com

# JWT future admin login
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
